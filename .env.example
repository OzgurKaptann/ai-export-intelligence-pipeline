# ============================================================
# AI Export Intelligence Pipeline — environment configuration
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# REQUIRED
# ----------------------------------------------------------
# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://user:password@localhost:5432/pipeline_db

# ----------------------------------------------------------
# LLM SETTINGS
# ----------------------------------------------------------
# Set to true (default) to use the built-in mock LLM provider.
# No API key is needed in mock mode — the full pipeline runs
# offline with deterministic synthetic enrichment outputs.
MOCK_LLM_ENABLED=true

# OpenAI API key — required only when MOCK_LLM_ENABLED=false.
OPENAI_API_KEY=

# Model to use when calling the real OpenAI API.
OPENAI_MODEL=gpt-4o-mini

# Per-request timeout in seconds for the real LLM API.
LLM_TIMEOUT_SECONDS=30

# ----------------------------------------------------------
# PIPELINE BEHAVIOUR
# ----------------------------------------------------------
# How to handle duplicate leads (same idempotency key).
# Options: skip (default) | update | reprocess
IDEMPOTENCY_MODE=skip

# Set to true to enable knowledge-base context retrieval.
KB_ENABLED=false

# Connection string for the knowledge base (if KB_ENABLED=true).
KB_CONNECTION_STRING=

# ----------------------------------------------------------
# RETRY POLICY
# ----------------------------------------------------------
# Maximum number of retry attempts for transient LLM failures.
RETRY_MAX_ATTEMPTS=3

# Base delay in seconds between retries (exponential backoff).
RETRY_DELAY_SECONDS=2.0

# ----------------------------------------------------------
# OBSERVABILITY
# ----------------------------------------------------------
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ----------------------------------------------------------
# TESTING
# ----------------------------------------------------------
# Hypothesis test profile: dev (20 examples) | ci (100 examples)
HYPOTHESIS_PROFILE=dev
